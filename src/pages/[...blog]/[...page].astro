---
export const prerender = true;

import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import PageLayout from '~/layouts/PageLayout.astro';
import PostList from '~/components/blog/PostList.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { getStaticPathsBlogList, findFeaturedPosts, getPermalink } from '~/lib/blog';
import { SITE, CATEGORIES } from '~/lib/constants';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
};

const { page } = Astro.props as any;
const featuredPosts = await findFeaturedPosts();
---

<PageLayout title={`Blog | ${SITE.name}`} description={SITE.description}>
  <section class="blog-page">
    <div class="blog-page-inner">
      <div class="blog-header reveal">
        <h1 class="blog-headline">The bgx Lens</h1>
        <p class="blog-subtitle">Solving complex InfoSec & Tech challenges with practical advice and strategic expertise.</p>
      </div>

      <div class="blog-layout">
        <div class="blog-main">
          <PostList posts={page.data} />
          <Pagination page={page} />
        </div>

        <aside class="blog-sidebar">
          <div class="sidebar-section glass-card-strong sidebar-sticky">
            <h3 class="sidebar-title">Featured Posts</h3>
            <ul class="sidebar-featured-list">
              {featuredPosts.map((post) => (
                <li class="sidebar-featured-item">
                  {post.resolvedImage && (
                    <a href={getPermalink(post.permalink, 'post')} class="sidebar-featured-image-link">
                      <Image
                        src={post.resolvedImage as any}
                        alt={post.title}
                        class="sidebar-featured-image"
                        width={64}
                        height={43}
                        loading="lazy"
                      />
                    </a>
                  )}
                  <div class="sidebar-featured-content">
                    <a href={getPermalink(post.permalink, 'post')} class="sidebar-featured-title">
                      {post.title}
                    </a>
                    <span class="sidebar-featured-date">
                      {post.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                    {post.category && (
                      <a href={getPermalink(post.category.slug, 'category')} class="category-badge">
                        <span class="category-dot"></span>
                        {post.category.title}
                      </a>
                    )}
                  </div>
                </li>
              ))}
            </ul>
            <div class="sidebar-section-footer">
              <a href={getPermalink('featured')} class="sidebar-link sidebar-link-arrow">
                View all featured posts <span aria-hidden="true">&rsaquo;</span>
              </a>
            </div>
          </div>

          <div class="sidebar-section glass-card-strong">
            <h3 class="sidebar-title">Categories</h3>
            <div class="sidebar-categories-list">
              {CATEGORIES.map((cat) => (
                <a
                  href={getPermalink(cat, 'category')}
                  class="sidebar-category-bar"
                  data-category={cat.toLowerCase()}
                >
                  <span class="sidebar-category-dot"></span>
                  <span class="sidebar-category-name">{cat}</span>
                </a>
              ))}
            </div>
            <div class="sidebar-section-footer">
              <a href={getPermalink('tags')} class="sidebar-link sidebar-link-arrow">
                View all tags <span aria-hidden="true">&rsaquo;</span>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Page wrapper — matches old AstroWind px-6 py-12 sm:py-16 lg:py-20 max-w-7xl */
  .blog-page {
    padding: 6rem 1.5rem 4rem;
  }

  @media (min-width: 640px) {
    .blog-page {
      padding: 7rem 1.5rem 4rem;
    }
  }

  @media (min-width: 1024px) {
    .blog-page {
      padding: 8rem 1.5rem 5rem;
    }
  }

  .blog-page-inner {
    width: 100%;
    max-width: 90rem;
    margin: 0 auto;
  }

  /* Header */
  .blog-header {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem;
  }

  .blog-headline {
    font-size: var(--fluid-h1);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .blog-subtitle {
    color: var(--color-text-subtle);
    font-size: var(--fluid-body);
    margin: 0;
  }

  /* Main layout — old AstroWind: grid-cols-4 gap-8 lg:gap-12 */
  .blog-layout {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .blog-layout {
      gap: 3rem;
    }
  }

  @media (max-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
  }

  .blog-main {
    min-width: 0;
  }

  /* Sidebar */
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: 5rem;
  }

  .sidebar-section {
    padding: 1.5rem;
  }

  .sidebar-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  /* Featured posts with thumbnails + category badges */
  .sidebar-featured-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .sidebar-featured-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-featured-item:first-child {
    padding-top: 0;
  }

  .sidebar-featured-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar-featured-image-link {
    flex-shrink: 0;
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .sidebar-featured-image {
    width: 4rem;
    height: 2.75rem;
    object-fit: cover;
    border-radius: 0.375rem;
  }

  .sidebar-featured-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .sidebar-featured-title {
    color: var(--color-text-subtle);
    font-size: var(--fluid-small);
    font-weight: 500;
    text-decoration: none;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .sidebar-featured-title:hover {
    color: var(--color-accent);
  }

  .sidebar-featured-date {
    color: var(--color-text-faint);
    font-size: 0.75rem;
  }

  .sidebar-section-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .sidebar-link {
    color: var(--color-text-subtle);
    font-size: var(--fluid-small);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--color-accent);
  }

  .sidebar-link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* Category bars — color via data attributes, zero inline styles */
  .sidebar-categories-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-category-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .sidebar-category-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .sidebar-category-name {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Security */
  .sidebar-category-bar[data-category="security"] {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.15) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="security"]:hover {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.25) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="security"] .sidebar-category-dot { background-color: #3b82f6; }
  .sidebar-category-bar[data-category="security"] .sidebar-category-name { color: #3b82f6; }

  /* AI */
  .sidebar-category-bar[data-category="ai"] {
    background: linear-gradient(90deg, rgba(34, 197, 94, 0.15) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="ai"]:hover {
    background: linear-gradient(90deg, rgba(34, 197, 94, 0.25) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="ai"] .sidebar-category-dot { background-color: #22c55e; }
  .sidebar-category-bar[data-category="ai"] .sidebar-category-name { color: #22c55e; }

  /* Automation */
  .sidebar-category-bar[data-category="automation"] {
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.15) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="automation"]:hover {
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.25) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="automation"] .sidebar-category-dot { background-color: #a855f7; }
  .sidebar-category-bar[data-category="automation"] .sidebar-category-name { color: #a855f7; }

  /* Tutorial */
  .sidebar-category-bar[data-category="tutorial"] {
    background: linear-gradient(90deg, rgba(249, 115, 22, 0.15) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="tutorial"]:hover {
    background: linear-gradient(90deg, rgba(249, 115, 22, 0.25) 0%, transparent 100%);
  }
  .sidebar-category-bar[data-category="tutorial"] .sidebar-category-dot { background-color: #f97316; }
  .sidebar-category-bar[data-category="tutorial"] .sidebar-category-name { color: #f97316; }
</style>
