---
export const prerender = true;

import type { GetStaticPaths } from 'astro';
import PageLayout from '~/layouts/PageLayout.astro';
import PostList from '~/components/blog/PostList.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { getStaticPathsBlogList, findFeaturedPosts, getPermalink } from '~/lib/blog';
import { SITE, CATEGORIES } from '~/lib/constants';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
};

const { page } = Astro.props;
const featuredPosts = await findFeaturedPosts();
---

<PageLayout title={`Blog | ${SITE.name}`} description={SITE.description}>
  <section class="section section-page-top">
    <div class="container">
      <div class="blog-header reveal">
        <h1 class="blog-headline"><span class="gradient-text">The bgx Lens</span></h1>
        <p class="blog-subtitle">Solving complex InfoSec & Tech challenges with practical advice and strategic expertise.</p>
      </div>

      <div class="blog-layout">
        <div class="blog-main">
          <PostList posts={page.data} />
          <Pagination page={page} />
        </div>

        <aside class="blog-sidebar">
          <div class="sidebar-section glass-card-strong sidebar-sticky">
            <h3 class="sidebar-title">Featured Posts</h3>
            <ul class="sidebar-list">
              {featuredPosts.map((post) => (
                <li>
                  <a href={getPermalink(post.permalink, 'post')} class="sidebar-link">
                    {post.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-section glass-card-strong">
            <h3 class="sidebar-title">Categories</h3>
            <div class="sidebar-categories">
              {CATEGORIES.map((cat) => (
                <a href={getPermalink(cat, 'category')} class="category-badge">
                  <span class="category-dot"></span>
                  {cat}
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-headline {
    font-size: var(--fluid-hero);
    margin: 0 0 1rem;
  }

  .blog-subtitle {
    color: var(--color-text-subtle);
    font-size: var(--fluid-body);
    max-width: 40rem;
    margin: 0 auto;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
  }

  .blog-main {
    min-width: 0;
  }

  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: 6rem;
  }

  .sidebar-section {
    padding: 1.5rem;
  }

  .sidebar-title {
    font-size: var(--fluid-h3);
    margin: 0 0 1rem;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-link {
    color: var(--color-text-subtle);
    font-size: var(--fluid-small);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--color-accent);
  }

  .sidebar-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
