---
export const prerender = true;

import type { GetStaticPaths } from 'astro';
import PageLayout from '~/layouts/PageLayout.astro';
import PostList from '~/components/blog/PostList.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { getStaticPathsBlogTag } from '~/lib/blog';
import { SITE } from '~/lib/constants';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  return await getStaticPathsBlogTag({ paginate });
};

const { page } = Astro.props;
const { tag } = Astro.props;
---

<PageLayout
  title={`#${tag.title} | ${SITE.name}`}
  description={`Posts tagged with "${tag.title}".`}
  robots={{ index: false, follow: true }}
>
  <section class="section section-page-top">
    <div class="container">
      <div class="tag-header reveal">
        <a href={`${SITE.base}/tags`} class="back-link">&larr; All tags</a>
        <h1 class="tag-headline"><span class="gradient-text">#{tag.title}</span></h1>
      </div>
      <PostList posts={page.data} />
      <Pagination page={page} />
    </div>
  </section>
</PageLayout>

<style>
  .tag-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-text-faint);
    font-size: var(--fluid-small);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .tag-headline {
    font-size: var(--fluid-hero);
    margin: 0;
  }
</style>
