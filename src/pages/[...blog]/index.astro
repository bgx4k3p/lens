---
// src/pages/[...blog]/index.astro
// Single blog post page with TOC sidebar
export const prerender = true;

import type { GetStaticPaths } from 'astro';
import PageLayout from '~/layouts/PageLayout.astro';
import PostContent from '~/components/blog/PostContent.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import TableOfContents from '~/components/blog/TableOfContents.astro';
import { getStaticPathsBlogPost, getCanonical } from '~/lib/blog';
import type { Post } from '~/lib/blog';

export const getStaticPaths: GetStaticPaths = async () => {
  return await getStaticPathsBlogPost();
};

const { post } = Astro.props as { post: Post };
const canonical = getCanonical(post.permalink);
---

<PageLayout
  title={post.title}
  description={post.excerpt}
  image={post.image}
  canonical={canonical}
>
  <section class="section section-page-top">
    <div class="container">
      <div class="post-page-layout">
        <div class="post-page-main">
          <PostContent post={post}>
            {post.Content && <post.Content />}
          </PostContent>
        </div>
        <TableOfContents />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <RelatedPosts post={post} />
    </div>
  </section>
</PageLayout>

<style>
  .post-page-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  @media (min-width: 1280px) {
    .post-page-layout {
      grid-template-columns: 1fr 14rem;
      max-width: 68rem;
    }
  }

  .post-page-main {
    min-width: 0;
  }
</style>
