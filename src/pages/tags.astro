---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import TagCloud from '~/components/blog/TagCloud.astro';
import { fetchPosts } from '~/lib/blog';
import { SITE } from '~/lib/constants';

const posts = await fetchPosts();
const tagMap = new Map<string, { slug: string; title: string; count: number }>();

posts.forEach((post) => {
  post.tags.forEach((tag) => {
    const existing = tagMap.get(tag.slug);
    if (existing) {
      existing.count++;
    } else {
      tagMap.set(tag.slug, { slug: tag.slug, title: tag.title, count: 1 });
    }
  });
});

const tags = Array.from(tagMap.values()).sort((a, b) => b.count - a.count);
---

<PageLayout title={`Tags | ${SITE.name}`} description="Browse all tags.">
  <section class="section section-page-top">
    <div class="container">
      <div class="tags-header reveal">
        <h1 class="tags-headline"><span class="gradient-text">Tags</span></h1>
        <p class="tags-subtitle">Browse posts by topic.</p>
      </div>
      <TagCloud tags={tags} />
    </div>
  </section>
</PageLayout>

<style>
  .tags-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tags-headline {
    font-size: var(--fluid-hero);
    margin: 0 0 1rem;
  }

  .tags-subtitle {
    color: var(--color-text-subtle);
    font-size: var(--fluid-body);
    margin: 0;
  }
</style>
