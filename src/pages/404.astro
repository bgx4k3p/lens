---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { SITE } from '~/lib/constants';
---

<PageLayout title={`Page Not Found | ${SITE.name}`} description="The page you are looking for does not exist." robots={{ index: false, follow: false }}>
  <section class="section section-page-top not-found">
    <div class="container">
      <div class="not-found-content reveal">
        <h1 class="not-found-code"><span class="gradient-text">404</span></h1>
        <p class="not-found-message">The page you are looking for does not exist.</p>
        <a href={SITE.base} class="btn-primary">Back to Home</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found-content {
    text-align: center;
    width: 100%;
  }

  .not-found-code {
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1rem;
  }

  .not-found-message {
    color: var(--color-text-subtle);
    font-size: var(--fluid-h3);
    margin: 0 0 2rem;
  }
</style>
