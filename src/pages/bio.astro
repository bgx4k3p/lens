---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import PostCard from '~/components/blog/PostCard.astro';
import { findLatestPosts } from '~/lib/blog';
import { SITE, SOCIAL_LINKS } from '~/lib/constants';

const latestPosts = await findLatestPosts(4);

const experience = [
  {
    title: 'VP Director, Info Sec Engineering',
    company: 'Fifth Third Bank',
    location: 'Cincinnati OH (Remote)',
    dates: '5/2022 – 12/2024',
    description: 'Led enterprise security engineering initiatives, driving strategic transformation of information security programs through AI-powered automation and modern security architecture.',
  },
  {
    title: 'Director, Info Sec',
    company: 'Freddie Mac',
    location: 'McLean VA',
    dates: '9/2017 – 5/2022',
    description: 'Directed information security operations and strategy, managing cross-functional teams to protect critical financial infrastructure and ensure regulatory compliance.',
  },
  {
    title: 'Info Sec Consultant',
    company: 'Axxum Technologies',
    location: 'Herndon VA',
    dates: '02/2016 – 09/2017',
    description: 'Provided expert security consulting services, conducting assessments and implementing security solutions for government and enterprise clients.',
  },
  {
    title: 'Penetration Tester, Red Team',
    company: 'Booz Allen Hamilton',
    location: 'McLean VA',
    dates: '08/2015 – 02/2016',
    description: 'Performed advanced adversary simulations and penetration testing engagements to identify vulnerabilities across enterprise environments.',
  },
  {
    title: 'Lead, Vulnerability Management',
    company: 'Booz Allen Hamilton',
    location: 'McLean VA',
    dates: '09/2013 – 08/2015',
    description: 'Led vulnerability management programs, coordinating scanning, analysis, and remediation efforts across large-scale environments.',
  },
  {
    title: 'Tech Lead, Systems Engineer',
    company: 'CompuCom',
    location: 'Herndon VA',
    dates: '04/2007 – 09/2013',
    description: 'Led systems engineering teams delivering enterprise IT infrastructure solutions, managing complex deployments and technical operations.',
  },
  {
    title: 'IT Consultant',
    company: 'Self-Employed',
    location: 'Bulgaria',
    dates: 'Early Career',
    description: 'Provided IT consulting and technical support services, building a foundation of hands-on experience across diverse technology environments.',
  },
];

const education = [
  {
    degree: 'MS Computer Forensics',
    school: 'George Mason University',
    years: '2016 – 2018',
    honors: 'Summa Cum Laude',
  },
  {
    degree: 'BS Information Security',
    school: 'George Mason University',
    years: '2012 – 2015',
    honors: 'Summa Cum Laude',
  },
];

const certifications = [
  'CISSP', 'GSLC', 'GCSA', 'GCPN', 'GXPN', 'OSCP',
  'CEH', 'Security+', 'Secure Infrastructure Specialist',
  'IT Operations Specialist', 'A+', 'NET+', 'MCP', 'MCTS', 'CCNA',
];
---

<PageLayout title={`About | ${SITE.name}`} description="Emil Chukalov — Transformative Security Leader, Strategic Visionary, and AI-Powered Automation Advocate.">

  <!-- Hero -->
  <section class="section section-page-top">
    <div class="container">
      <div class="bio-hero reveal">
        <h1 class="bio-name"><span class="gradient-text">Emil Chukalov</span></h1>
        <p class="bio-title">Transformative Security Leader | Strategic Visionary | AI-Powered Automation Advocate</p>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container">
      <div class="bio-about reveal">
        <h2 class="bio-section-heading">About Me</h2>
        <div class="bio-about-content">
          <p>
            I am a transformative security leader with over 17 years of experience in information security,
            IT operations, and strategic technology leadership. My career spans government agencies, financial
            institutions, and consulting firms, where I have consistently delivered innovative security programs
            that balance risk management with business enablement.
          </p>
          <p>
            I am passionate about leveraging AI and automation to solve complex security challenges at scale.
            My approach combines deep technical expertise with strategic vision, enabling organizations to build
            resilient security postures while embracing digital transformation.
          </p>
        </div>
        <div class="bio-social">
          <a href={SOCIAL_LINKS.linkedin} class="btn-ghost" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href={SOCIAL_LINKS.github} class="btn-ghost" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={`mailto:${SOCIAL_LINKS.email}`} class="btn-ghost">Mail</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Experience -->
  <section class="section">
    <div class="container">
      <h2 class="bio-section-heading reveal">Work Experience</h2>
      <div class="timeline">
        {experience.map((job, i) => (
          <div class={`timeline-item reveal reveal-delay-${Math.min(i + 1, 5)}`}>
            <div class="timeline-marker"></div>
            <div class="glass-card timeline-card">
              <h3 class="timeline-title">{job.title}</h3>
              <p class="timeline-company">{job.company} — {job.location}</p>
              <p class="timeline-dates">{job.dates}</p>
              <p class="timeline-description">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="section">
    <div class="container">
      <h2 class="bio-section-heading reveal">Education</h2>
      <div class="education-grid">
        {education.map((edu, i) => (
          <div class={`glass-card education-card reveal reveal-delay-${i + 1}`}>
            <h3 class="education-degree">{edu.degree}</h3>
            <p class="education-school">{edu.school}</p>
            <p class="education-years">{edu.years}</p>
            <p class="education-honors">{edu.honors}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section">
    <div class="container">
      <h2 class="bio-section-heading reveal">Certifications</h2>
      <div class="cert-grid">
        {certifications.map((cert, i) => (
          <div class={`glass-card cert-card reveal reveal-delay-${Math.min((i % 5) + 1, 5)}`}>
            <span class="cert-name">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="section">
    <div class="container">
      <h2 class="bio-section-heading reveal">Latest Posts</h2>
      <div class="bio-posts-grid">
        {latestPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .bio-hero {
    text-align: center;
    padding-bottom: 2rem;
  }

  .bio-name {
    font-size: var(--fluid-hero);
    margin: 0 0 1rem;
  }

  .bio-title {
    color: var(--color-text-subtle);
    font-size: var(--fluid-h3);
    font-weight: 500;
    margin: 0;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .bio-section-heading {
    font-size: var(--fluid-h2);
    margin: 0 0 2rem;
    text-align: center;
  }

  .bio-about {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .bio-about-content {
    color: var(--color-text-subtle);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .bio-about-content p {
    margin: 0 0 1rem;
  }

  .bio-social {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Timeline */
  .timeline {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2rem;
  }

  .timeline-marker {
    position: absolute;
    left: -1.625rem;
    top: 1.5rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
  }

  .timeline-card {
    padding: 1.5rem;
    margin-left: 1rem;
  }

  .timeline-title {
    font-size: var(--fluid-h3);
    margin: 0 0 0.25rem;
  }

  .timeline-company {
    color: var(--color-accent-text);
    font-weight: 500;
    margin: 0 0 0.25rem;
    font-size: var(--fluid-small);
  }

  .timeline-dates {
    color: var(--color-text-faint);
    font-size: var(--fluid-small);
    margin: 0 0 0.75rem;
  }

  .timeline-description {
    color: var(--color-text-subtle);
    margin: 0;
    line-height: 1.6;
  }

  /* Education */
  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 48rem;
    margin: 0 auto;
  }

  .education-card {
    padding: 1.5rem;
    text-align: center;
  }

  .education-degree {
    font-size: var(--fluid-h3);
    margin: 0 0 0.5rem;
  }

  .education-school {
    color: var(--color-accent-text);
    font-weight: 500;
    margin: 0 0 0.25rem;
  }

  .education-years {
    color: var(--color-text-faint);
    font-size: var(--fluid-small);
    margin: 0 0 0.5rem;
  }

  .education-honors {
    color: var(--color-success);
    font-weight: 600;
    font-size: var(--fluid-small);
    margin: 0;
  }

  /* Certifications */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    max-width: 60rem;
    margin: 0 auto;
  }

  .cert-card {
    padding: 1rem 1.25rem;
    text-align: center;
  }

  .cert-name {
    font-weight: 600;
    font-size: var(--fluid-small);
    color: var(--color-text);
  }

  /* Latest Posts */
  .bio-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
