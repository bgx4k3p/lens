---
import type { Post } from '~/lib/blog';
import { getPermalink } from '~/lib/blog';
import { SITE } from '~/lib/constants';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formattedDate = post.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdateDate = post.updateDate
  ? post.updateDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const postUrl = `${SITE.site}${getPermalink(post.permalink, 'post')}`;
const shareTextEncoded = encodeURIComponent(post.title);
const shareUrlEncoded = encodeURIComponent(postUrl);
const twitterUrl = `https://twitter.com/intent/tweet?text=${shareTextEncoded}&url=${shareUrlEncoded}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`;
---

<header class="post-header">
  <h1 class="post-title">{post.title}</h1>
  <div class="post-meta">
    <time datetime={post.publishDate.toISOString()}>{formattedDate}</time>
    {post.category && (
      <a href={getPermalink(post.category.slug, 'category')} class="category-badge">
        <span class="category-dot"></span>
        {post.category.title}
      </a>
    )}
    {post.readingTime && <span>{post.readingTime} min read</span>}
    {formattedUpdateDate && <span>Updated {formattedUpdateDate}</span>}
  </div>
  {(post.tags || []).length > 0 && (
    <div class="post-tags">
      {post.tags.map((tag) => (
        <a href={getPermalink(tag.slug, 'tag')} class="tag-chip">{tag.title}</a>
      ))}
    </div>
  )}
</header>

<article class="prose prose-lg max-w-none">
  <slot />
</article>

<footer class="post-share">
  <span class="post-share-label">Share</span>
  <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="icon-btn" aria-label="Share on X">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </a>
  <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="icon-btn" aria-label="Share on LinkedIn">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
  </a>
  <button class="icon-btn" aria-label="Copy link" data-copy-url={postUrl} onclick="navigator.clipboard.writeText(this.dataset.copyUrl);this.setAttribute('aria-label','Copied!')">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
  </button>
</footer>

<style>
  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: var(--fluid-h1);
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    color: var(--color-text-faint);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
  }

  .post-share-label {
    color: var(--color-text-subtle);
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>
