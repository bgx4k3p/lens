---
import { Image } from 'astro:assets';
import type { Post } from '~/lib/blog';
import { getPermalink } from '~/lib/blog';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const postUrl = getPermalink(post.permalink, 'post');
const formattedDate = post.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="glass-card post-card">
  {post.resolvedImage && (
    <a href={postUrl} class="post-card-image-link">
      <Image
        src={post.resolvedImage}
        alt={post.title}
        class="post-card-image"
        loading="lazy"
        decoding="async"
        widths={[400, 800]}
      />
    </a>
  )}
  <div class="post-card-body">
    {post.category && (
      <a href={getPermalink(post.category.slug, 'category')} class="category-badge">
        <span class="category-dot"></span>
        {post.category.title}
      </a>
    )}
    <h3 class="post-card-title">
      <a href={postUrl}>{post.title}</a>
    </h3>
    {post.excerpt && (
      <p class="post-card-excerpt">{post.excerpt}</p>
    )}
    <div class="post-card-meta">
      <time datetime={post.publishDate.toISOString()}>{formattedDate}</time>
      {post.readingTime && <span>{post.readingTime} min read</span>}
    </div>
    {(post.tags || []).length > 0 && (
      <div class="post-card-tags">
        {post.tags.map((tag) => (
          <a href={getPermalink(tag.slug, 'tag')} class="tag-chip">{tag.title}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .post-card-image-link {
    display: block;
  }

  .post-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 1rem 1rem 0 0;
  }

  .post-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .post-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
  }

  .post-card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card-title a:hover {
    color: var(--color-accent);
  }

  .post-card-excerpt {
    color: var(--color-text-subtle);
    font-size: var(--fluid-small);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-faint);
    font-size: 0.8125rem;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }
</style>
