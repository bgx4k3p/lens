---
import { Image } from 'astro:assets';
import type { Post } from '~/lib/blog';
import { getPermalink } from '~/lib/blog';
import { Clock } from 'lucide-astro';

interface Props {
  post: Post;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const postUrl = getPermalink(post.permalink, 'post');
const formattedDate = post.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const delayClass = `reveal-delay-${Math.min((index % 5) + 1, 5)}`;
---

<article class={`post-card reveal ${delayClass} ${post.resolvedImage ? 'has-image' : ''}`}>
  {post.resolvedImage && (
    <a href={postUrl} class="post-card-image-link">
      <div class="post-card-image-wrap">
        <Image
          src={post.resolvedImage as any}
          alt={post.title}
          class="post-card-image"
          widths={[400, 900]}
          width={900}
          loading="lazy"
          decoding="async"
        />
      </div>
    </a>
  )}
  <div class="post-card-body">
    <div class="post-card-meta">
      <Clock size={14} />
      <time datetime={post.publishDate.toISOString()}>{formattedDate}</time>
      {post.category && (
        <Fragment>
          <span>&middot;</span>
          <a href={getPermalink(post.category.slug, 'category')} class="post-card-category">
            {post.category.title}
          </a>
        </Fragment>
      )}
    </div>
    <h2 class="post-card-title">
      <a href={postUrl}>{post.title}</a>
    </h2>
    {post.excerpt && (
      <p class="post-card-excerpt">{post.excerpt}</p>
    )}
    {(post.tags || []).length > 0 && (
      <div class="post-card-tags">
        {post.tags.map((tag) => (
          <a href={getPermalink(tag.slug, 'tag')} class="tag-chip">{tag.title}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    display: block;
    max-width: 28rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .post-card {
      max-width: none;
      margin: 0;
    }

    .post-card.has-image {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (min-width: 1280px) {
    .post-card.has-image {
      grid-template-columns: 3fr 2fr;
      gap: 2.5rem;
    }
  }

  /* Image */
  .post-card-image-link {
    display: block;
  }

  .post-card-image-wrap {
    position: relative;
    height: 0;
    padding-bottom: 56.25%;
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--color-bg-elevated);
    box-shadow: var(--glass-shadow);
  }

  @media (min-width: 768px) {
    .post-card-image-wrap {
      padding-bottom: 75%;
      height: 18rem;
    }
  }

  @media (min-width: 1024px) {
    .post-card-image-wrap {
      padding-bottom: 56.25%;
      height: auto;
    }
  }

  .post-card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
    transition: transform 0.4s ease;
  }

  .post-card-image-link:hover .post-card-image {
    transform: scale(1.03);
  }

  /* Body */
  .post-card-body {
    margin-top: 0.5rem;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-faint);
    font-size: 0.8125rem;
    margin-bottom: 0.375rem;
  }

  .post-card-category {
    color: var(--color-text-faint);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-card-category:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }

  @media (min-width: 640px) {
    .post-card-title {
      font-size: 1.5rem;
    }
  }

  .post-card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-card-title a:hover {
    color: var(--color-accent);
  }

  .post-card-excerpt {
    color: var(--color-text-subtle);
    font-size: 1.0625rem;
    line-height: 1.6;
    margin: 0;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
</style>
