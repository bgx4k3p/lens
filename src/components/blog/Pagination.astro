---
// src/components/blog/Pagination.astro
// Pagination nav with prev/next buttons
interface Props {
  page?: { url: { prev?: string; next?: string } };
  prevUrl?: string;
  nextUrl?: string;
}

const { page, prevUrl: directPrev, nextUrl: directNext } = Astro.props;
const prevUrl = directPrev || page?.url?.prev;
const nextUrl = directNext || page?.url?.next;
---

{(prevUrl || nextUrl) && (
  <nav class="pagination" aria-label="Pagination">
    {prevUrl ? (
      <a href={prevUrl} class="btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Previous
      </a>
    ) : <span></span>}
    {nextUrl ? (
      <a href={nextUrl} class="btn-ghost">
        Next
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    ) : <span></span>}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }
</style>
