---
import { getPermalink } from '~/lib/blog';

interface Props {
  tags: { slug: string; title: string; count: number }[];
}

const { tags } = Astro.props;
const maxCount = Math.max(...tags.map((t) => t.count), 1);
---

<div class="tag-cloud">
  {tags.map((tag) => {
    const sizeClass =
      tag.count / maxCount > 0.75
        ? 'tag-chip-lg'
        : tag.count / maxCount > 0.4
          ? 'tag-chip-md'
          : '';
    return (
      <a href={getPermalink(tag.slug, 'tag')} class:list={['tag-chip', sizeClass]}>
        {tag.title}
        <span class="tag-chip-count">{tag.count}</span>
      </a>
    );
  })}
</div>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip-md {
    font-size: 0.925rem;
    padding: 0.35rem 0.85rem;
  }

  .tag-chip-lg {
    font-size: 1.05rem;
    padding: 0.4rem 1rem;
  }

  .tag-chip-count {
    opacity: 0.6;
    font-size: 0.75em;
    margin-left: 0.25rem;
  }
</style>
